{
    "version": 2,
    "builds": [
        {
            "src": "api/translate.py",
            "use": "@vercel/python",
            "config": {
                "maxLambdaSize": "50mb"
            }
        }
    ],
    "routes": [
        {
            "src": "/api/translate",
            "dest": "/api/translate.py"
        },
        {
            "src": "/(.*)",
            "dest": "/public/$1"
        }
    ],
    "functions": {
        "api/translate.py": {
            "memory": 1024,
            "maxDuration": 60
        }
    }
}